# ── LLM Local (Ollama) ────────────────────────────
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llama3.2-vision

# Parallélisme & Concurrence
OLLAMA_NUM_PARALLEL=1
FSM_CONCURRENT_REQUESTS=2

# ── Gemini (Google GenAI) ─────────────────────────
# Obtenez une clé sur https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── OpenRouter (API Cloud prioritaire) ────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# ── Chemins & Configuration ───────────────────────
ANONYMIZED_TELEMETRY=False
CHROMA_DB_PATH=data/chroma_db_hierarchical
OUTPUT_IMAGE_DIR=data/output_images
OUTPUT_JSON_DIR=data/output_json
MODELS_CACHE_DIR=data/models_cache
