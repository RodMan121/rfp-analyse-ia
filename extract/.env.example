# ── LLM Local (Ollama) ────────────────────────────
OLLAMA_TEXT_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llama3.2-vision

# Parallélisme Ollama (nécessite: ollama serve --parallel N)
OLLAMA_NUM_PARALLEL=1

# ── Gemini (Google GenAI) ─────────────────────────
# Obtenez une clé sur https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Chemins & Configuration ───────────────────────
CHROMA_DB_PATH=data/chroma_db_hierarchical
OUTPUT_IMAGE_DIR=data/output_images
OUTPUT_JSON_DIR=data/output_json
MODELS_CACHE_DIR=data/models_cache
