# .env.example — Copier en .env et remplir les valeurs
# Ne jamais committer le fichier .env dans git !

# ── OBLIGATOIRE — Gemini (Niveau 2) ───────────────
# Obtenir sur : https://aistudio.google.com/apikey
# Tier gratuit : 1500 req/jour (gemini-2.0-flash)
GOOGLE_API_KEY=your_google_api_key_here

# ── OPTIONNEL — Niveau 3 (plus tard) ──────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
